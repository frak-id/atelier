{
  "name": "atelier",
  "version": "0.1.3",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "knip": "knip",
    "version:bump": "bun run scripts/bump-version.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "bun run --filter @konfeature/opencode-atelier build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "2.31.0",
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "^7.0.0-dev.20260415.1",
    "knip": "^6.4.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2"
  },
  "dependencies": {}
}
