{
  "name": "@konfeature/opencode-atelier",
  "version": "0.1.0",
  "description": "OpenCode plugin that dispatches coding tasks to Atelier sandboxes (self-hosted Kata Containers dev environments).",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "atelier",
    "sandbox",
    "ai-agent",
    "coding-agent",
    "kata-containers"
  ],
  "author": "konfeature",
  "license": "MIT",
  "homepage": "https://github.com/frak-id/atelier/tree/main/packages/opencode-atelier#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frak-id/atelier.git",
    "directory": "packages/opencode-atelier"
  },
  "bugs": {
    "url": "https://github.com/frak-id/atelier/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.9",
    "xdg-basedir": "^5.1.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.37",
    "@opencode-ai/sdk": "^1.14.37",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@frak/atelier-manager": "workspace:*",
    "@opencode-ai/plugin": "^1.14.37",
    "@opencode-ai/sdk": "1.14.37",
    "@types/bun": "^1.3.12",
    "zod": "^4.3.6"
  }
}
