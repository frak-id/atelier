{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "domain": {
      "default": {},
      "type": "object",
      "properties": {
        "baseDomain": {
          "default": "localhost",
          "type": "string"
        },
        "dashboard": {
          "default": "",
          "type": "string"
        },
        "tls": {
          "default": {},
          "type": "object",
          "properties": {
            "email": {
              "default": "",
              "type": "string"
            },
            "certPath": {
              "default": "",
              "type": "string"
            },
            "keyPath": {
              "default": "",
              "type": "string"
            }
          }
        },
        "ssh": {
          "default": {},
          "type": "object",
          "properties": {
            "port": {
              "default": 2222,
              "type": "number"
            },
            "hostname": {
              "default": "",
              "type": "string"
            }
          }
        }
      }
    },
    "auth": {
      "default": {},
      "type": "object",
      "properties": {
        "github": {
          "default": {},
          "type": "object",
          "properties": {
            "clientId": {
              "default": "",
              "type": "string"
            },
            "clientSecret": {
              "default": "",
              "type": "string"
            }
          }
        },
        "jwtSecret": {
          "default": "dev-secret-change-in-production",
          "type": "string"
        },
        "allowedOrg": {
          "type": "string"
        },
        "allowedUsers": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "server": {
      "default": {},
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "anyOf": [
            {
              "const": "production",
              "type": "string"
            },
            {
              "const": "mock",
              "type": "string"
            }
          ]
        },
        "port": {
          "default": 4000,
          "type": "number"
        },
        "host": {
          "default": "0.0.0.0",
          "type": "string"
        },
        "maxSandboxes": {
          "default": 20,
          "type": "number"
        },
        "maxActiveTasks": {
          "default": 10,
          "type": "number"
        },
        "mcpToken": {
          "default": "",
          "type": "string"
        }
      }
    },
    "kubernetes": {
      "default": {},
      "type": "object",
      "properties": {
        "namespace": {
          "default": "atelier-sandboxes",
          "type": "string"
        },
        "systemNamespace": {
          "default": "atelier-system",
          "type": "string"
        },
        "kubeconfig": {
          "default": "/etc/rancher/k3s/k3s.yaml",
          "type": "string"
        },
        "runtimeClass": {
          "default": "kata-clh",
          "type": "string"
        },
        "ingressClassName": {
          "default": "",
          "type": "string"
        },
        "registryUrl": {
          "default": "zot.atelier-system.svc:5000",
          "type": "string"
        },
        "npmRegistryUrl": {
          "default": "",
          "type": "string"
        },
        "storageClass": {
          "default": "",
          "type": "string"
        },
        "volumeSnapshotClass": {
          "default": "",
          "type": "string"
        },
        "defaultVolumeSize": {
          "default": "10Gi",
          "type": "string"
        },
        "vsCodeIngressAnnotations": {
          "default": {},
          "type": "object",
          "patternProperties": {
            "^(.*)$": {
              "type": "string"
            }
          }
        },
        "openCodeIngressAnnotations": {
          "default": {},
          "type": "object",
          "patternProperties": {
            "^(.*)$": {
              "type": "string"
            }
          }
        },
        "managerUrl": {
          "default": "",
          "type": "string"
        }
      }
    },
    "sandbox": {
      "default": {},
      "type": "object",
      "properties": {
        "defaultImage": {
          "default": "dev-base",
          "type": "string"
        },
        "imagesDirectory": {
          "default": "/opt/atelier/infra/images",
          "type": "string"
        },
        "git": {
          "default": {},
          "type": "object",
          "properties": {
            "email": {
              "default": "sandbox@atelier.dev",
              "type": "string"
            },
            "name": {
              "default": "Sandbox User",
              "type": "string"
            }
          }
        }
      }
    },
    "ports": {
      "default": {},
      "type": "object",
      "properties": {
        "vscode": {
          "default": 8080,
          "type": "number"
        },
        "opencode": {
          "default": 3000,
          "type": "number"
        },
        "browser": {
          "default": 6080,
          "type": "number"
        },
        "terminal": {
          "default": 7681,
          "type": "number"
        },
        "agent": {
          "default": 9998,
          "type": "number"
        }
      }
    },
    "imageBuilder": {
      "default": {},
      "type": "object",
      "properties": {
        "kind": {
          "default": "kaniko",
          "anyOf": [
            {
              "const": "kaniko",
              "type": "string"
            },
            {
              "const": "buildkit",
              "type": "string"
            }
          ]
        },
        "image": {
          "default": "",
          "type": "string"
        },
        "endpoint": {
          "default": "",
          "type": "string"
        },
        "cacheRepo": {
          "default": "",
          "type": "string"
        },
        "insecureRegistry": {
          "default": true,
          "type": "boolean"
        },
        "tls": {
          "default": {},
          "type": "object",
          "properties": {
            "secretName": {
              "default": "",
              "type": "string"
            },
            "serverName": {
              "default": "",
              "type": "string"
            }
          }
        }
      }
    },
    "integrations": {
      "default": {},
      "type": "object",
      "properties": {
        "cliproxy": {
          "default": {},
          "type": "object",
          "properties": {
            "url": {
              "default": "",
              "type": "string"
            },
            "apiKey": {
              "default": "",
              "type": "string"
            },
            "managementKey": {
              "default": "",
              "type": "string"
            }
          }
        }
      }
    }
  }
}
