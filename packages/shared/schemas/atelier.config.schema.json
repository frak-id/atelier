{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "domain": {
      "default": {},
      "type": "object",
      "properties": {
        "baseDomain": {
          "default": "localhost",
          "type": "string"
        },
        "dashboard": {
          "default": "",
          "type": "string"
        },
        "tls": {
          "default": {},
          "type": "object",
          "properties": {
            "email": {
              "default": "",
              "type": "string"
            },
            "certPath": {
              "default": "",
              "type": "string"
            },
            "keyPath": {
              "default": "",
              "type": "string"
            }
          }
        },
        "ssh": {
          "default": {},
          "type": "object",
          "properties": {
            "port": {
              "default": 2222,
              "type": "number"
            },
            "hostname": {
              "default": "",
              "type": "string"
            }
          }
        }
      }
    },
    "auth": {
      "default": {},
      "type": "object",
      "properties": {
        "github": {
          "default": {},
          "type": "object",
          "properties": {
            "clientId": {
              "default": "",
              "type": "string"
            },
            "clientSecret": {
              "default": "",
              "type": "string"
            }
          }
        },
        "jwtSecret": {
          "default": "dev-secret-change-in-production",
          "type": "string"
        },
        "allowedOrg": {
          "type": "string"
        },
        "allowedUsers": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "server": {
      "default": {},
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "anyOf": [
            {
              "const": "production",
              "type": "string"
            },
            {
              "const": "mock",
              "type": "string"
            }
          ]
        },
        "port": {
          "default": 4000,
          "type": "number"
        },
        "host": {
          "default": "0.0.0.0",
          "type": "string"
        },
        "maxSandboxes": {
          "default": 20,
          "type": "number"
        },
        "maxActiveTasks": {
          "default": 10,
          "type": "number"
        },
        "mcpToken": {
          "default": "",
          "type": "string"
        }
      }
    },
    "kubernetes": {
      "default": {},
      "type": "object",
      "properties": {
        "namespace": {
          "default": "atelier-sandboxes",
          "type": "string"
        },
        "systemNamespace": {
          "default": "atelier-system",
          "type": "string"
        },
        "kubeconfig": {
          "default": "/etc/rancher/k3s/k3s.yaml",
          "type": "string"
        },
        "runtimeClass": {
          "default": "kata-clh",
          "type": "string"
        },
        "registryUrl": {
          "default": "zot.atelier-system.svc:5000",
          "type": "string"
        },
        "verdaccioImage": {
          "default": "verdaccio/verdaccio:6",
          "type": "string"
        },
        "storageClass": {
          "default": "",
          "type": "string"
        },
        "volumeSnapshotClass": {
          "default": "",
          "type": "string"
        },
        "defaultVolumeSize": {
          "default": "10Gi",
          "type": "string"
        }
      }
    },
    "sandbox": {
      "default": {},
      "type": "object",
      "properties": {
        "defaultImage": {
          "default": "dev-base",
          "type": "string"
        },
        "imagesDirectory": {
          "default": "/opt/atelier/infra/images",
          "type": "string"
        },
        "git": {
          "default": {},
          "type": "object",
          "properties": {
            "email": {
              "default": "sandbox@atelier.dev",
              "type": "string"
            },
            "name": {
              "default": "Sandbox User",
              "type": "string"
            }
          }
        }
      }
    },
    "advanced": {
      "default": {},
      "type": "object",
      "properties": {
        "vm": {
          "default": {},
          "type": "object",
          "properties": {
            "vscode": {
              "default": {},
              "type": "object",
              "properties": {
                "port": {
                  "default": 8080,
                  "type": "number"
                },
                "version": {
                  "default": "4.109.2",
                  "type": "string"
                }
              }
            },
            "opencode": {
              "default": {},
              "type": "object",
              "properties": {
                "port": {
                  "default": 3000,
                  "type": "number"
                },
                "version": {
                  "default": "1.2.10",
                  "type": "string"
                }
              }
            },
            "browser": {
              "default": {},
              "type": "object",
              "properties": {
                "port": {
                  "default": 6080,
                  "type": "number"
                }
              }
            },
            "terminal": {
              "default": {},
              "type": "object",
              "properties": {
                "port": {
                  "default": 7681,
                  "type": "number"
                }
              }
            },
            "agent": {
              "default": {},
              "type": "object",
              "properties": {
                "port": {
                  "default": 9999,
                  "type": "number"
                }
              }
            }
          }
        },
        "server": {
          "default": {},
          "type": "object",
          "properties": {
            "verdaccio": {
              "default": {},
              "type": "object",
              "properties": {
                "port": {
                  "default": 4873,
                  "type": "number"
                },
                "version": {
                  "default": "6.2.5",
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "integrations": {
      "default": {},
      "type": "object",
      "properties": {
        "slack": {
          "default": {},
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "botToken": {
              "default": "",
              "type": "string"
            },
            "signingSecret": {
              "default": "",
              "type": "string"
            }
          }
        }
      }
    }
  }
}
